# ============================================================
# SGLang Commander — Environment Configuration
# ============================================================
# Copy this file to `.env` and fill in the values.
# All values have sensible defaults; only override what you need.
# ============================================================

# --- Security ---
# JWT secret for token signing. Auto-generated on first run if empty.
JWT_SECRET=

# --- Server ---
HOST=0.0.0.0
PORT=8080
DEBUG=false

# --- Database ---
# SQLite (default) or PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./data/sglang_commander.db

# --- CORS ---
# Comma-separated list of allowed origins. Use * only for development.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- SGLang Backend ---
SGLANG_HOST=127.0.0.1
SGLANG_PORT=30000

# --- llama.cpp Backend ---
# Path to llama-server binary. Auto-detected via PATH if empty.
LLAMACPP_BINARY_PATH=
LLAMACPP_HOST=127.0.0.1
LLAMACPP_PORT=8081
# Directory containing GGUF models for router mode auto-discovery
LLAMACPP_MODELS_DIR=

# --- Ollama Backend ---
OLLAMA_HOST=http://localhost:11434

# --- Environment Auto-Detection ---
# Leave empty to auto-detect from system. Override for custom setups.
CUDA_HOME=
VENV_PATH=

# Extra environment variables to pass to backend processes (JSON dict)
# Example: {"PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"}
SGLANG_EXTRA_ENV={}

# --- HuggingFace ---
HF_TOKEN=

# Directories to scan for local models (comma-separated, in addition to HF cache)
MODEL_SCAN_DIRS=

# --- ZeroTier (optional) ---
ZEROTIER_CENTRAL_TOKEN=

# --- Updates ---
UPDATE_CHECK_URL=https://api.github.com/repos/Caiolinooo/sglang-commander/releases/latest
# (Optional) Secret key to authenticate GitHub Webhook requests
WEBHOOK_SECRET=

